<%- include('partials/header', { title: 'High-Octane Community Portal' }) %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Hero Section -->
  <div class="relative bg-gradient-to-r from-[#18191C] to-[#252830] rounded-3xl border border-gray-800 p-8 sm:p-14 overflow-hidden shadow-2xl mb-14">
    <div class="absolute -right-10 -bottom-10 w-96 h-96 bg-[#5865F2] bg-opacity-10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute right-1/3 -top-10 w-80 h-80 bg-purple-500 bg-opacity-10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 max-w-2xl">
      <div class="inline-flex items-center space-x-2 px-3.5 py-1.5 bg-[#5865F2] bg-opacity-15 rounded-full border border-[#5865F2] border-opacity-30 text-[#5865F2] text-xs font-extrabold uppercase tracking-wider mb-6">
        <span class="flex h-2 w-2 relative"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#5865F2] opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-[#5865F2]"></span></span>
        <span><%= siteMotd %></span>
      </div>

      <h1 class="text-4xl sm:text-6xl font-extrabold text-white tracking-tight leading-tight mb-6">
        Welcome to the <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#5865F2] to-purple-400"><%= siteTitle %></span> Gaming Network
      </h1>
      
      <p class="text-base sm:text-lg text-gray-300 mb-10 leading-relaxed">
        Experience premium, lag-free multiplayer servers. Built on enterprise container technology with real-time AI log watchdogs, live web RCON, and interactive community forums.
      </p>

      <div class="flex flex-wrap items-center gap-4">
        <a href="<%= user ? '/dashboard' : '/login' %>" class="px-8 py-4 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-base rounded-2xl shadow-xl transition transform hover:scale-105 flex items-center space-x-3">
          <span>🚀 Deploy / Manage Server</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>

        <a href="/forums" class="px-8 py-4 bg-gray-800 hover:bg-gray-700 font-bold text-gray-200 text-base rounded-2xl border border-gray-700 transition flex items-center space-x-3">
          <span>💬 Forums & Live Chat</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main Grid Content -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

    <!-- Left 2 Cols: Latest News & Announcements -->
    <div class="lg:col-span-2 space-y-8">
      <div class="flex items-center justify-between border-b border-gray-800 pb-4">
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 bg-brand-500 bg-opacity-10 text-brand-500 rounded-xl flex items-center justify-center font-bold">📢</div>
          <h2 class="text-2xl font-extrabold text-white tracking-tight">Community Announcements</h2>
        </div>
        <span class="text-xs font-semibold text-gray-500">Live CMS Feed</span>
      </div>

      <% if (news.length === 0) { %>
        <div class="bg-[#18191C] rounded-2xl border border-gray-800 p-12 text-center text-gray-500">
          <svg class="w-12 h-12 mx-auto text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          <p class="font-medium text-sm">No announcements published yet. Check back soon!</p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <% news.forEach(item => { %>
            <a href="/news/<%= item.id %>" class="group bg-[#18191C] rounded-2xl border border-gray-800 hover:border-brand-500 transition shadow-lg overflow-hidden flex flex-col">
              <div class="h-44 bg-gray-800 relative overflow-hidden">
                <img src="<%= item.image_url %>" class="w-full h-full object-cover group-hover:scale-105 transition transform duration-500">
                <div class="absolute inset-0 bg-gradient-to-t from-[#18191C] via-transparent to-transparent"></div>
              </div>
              <div class="p-6 flex-grow flex flex-col justify-between space-y-4">
                <div>
                  <div class="flex items-center space-x-2 text-[11px] font-bold text-brand-500 uppercase tracking-wider mb-2">
                    <span><%= new Date(item.created_at).toLocaleDateString() %></span>
                    <span>•</span>
                    <span>By <%= item.author_name || 'System' %></span>
                  </div>
                  <h3 class="text-xl font-bold text-white group-hover:text-brand-500 transition leading-snug"><%= item.title %></h3>
                  <p class="text-sm text-gray-400 mt-2 line-clamp-2 leading-relaxed"><%= item.summary || item.content.slice(0, 120) %>...</p>
                </div>
                <div class="flex items-center text-xs font-bold text-brand-500 group-hover:translate-x-1 transition">
                  <span>Read Full Article</span>
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Right 1 Col: Public Server Roster & Custom Navigation Widgets -->
    <div class="space-y-8">
      
      <!-- Live Server Roster Widget -->
      <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-7 shadow-xl">
        <div class="flex items-center justify-between border-b border-gray-800 pb-4 mb-6">
          <div class="flex items-center space-x-2.5">
            <span class="flex h-2.5 w-2.5 relative"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span><span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span></span>
            <h3 class="font-extrabold text-white tracking-tight">Public Live Servers</h3>
          </div>
          <span class="text-[11px] font-bold text-green-400 px-2 py-0.5 bg-green-500 bg-opacity-10 rounded-full"><%= publicServers.length %> Online</span>
        </div>

        <% if (publicServers.length === 0) { %>
          <div class="py-8 text-center text-xs text-gray-500">
            <p>No public game servers currently active.</p>
            <a href="<%= user ? '/dashboard' : '/login' %>" class="inline-block mt-3 text-brand-500 hover:underline font-bold">Start your server →</a>
          </div>
        <% } else { %>
          <div class="space-y-4">
            <% publicServers.forEach(srv => { %>
              <div class="p-4 bg-[#0E0F10] rounded-2xl border border-gray-800 flex items-center justify-between hover:border-gray-700 transition">
                <div class="pr-3">
                  <p class="text-xs font-extrabold text-white truncate"><%= srv.name %></p>
                  <p class="text-[11px] font-mono text-brand-500 mt-0.5"><%= srv.ip %>:<%= srv.port %></p>
                </div>
                <div class="flex flex-col items-end flex-shrink-0">
                  <span class="px-2.5 py-1 bg-green-500 bg-opacity-10 text-green-400 text-[10px] font-extrabold uppercase rounded-lg">Active</span>
                  <span class="text-[10px] text-gray-500 mt-1"><%= srv.egg_name %></span>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Custom CMS Web Pages Sidebar Widget -->
      <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-7 shadow-xl">
        <h3 class="font-extrabold text-white tracking-tight border-b border-gray-800 pb-4 mb-6 flex items-center space-x-2.5">
          <span class="text-brand-500">📑</span>
          <span>Information & Rules</span>
        </h3>

        <% if (pages.length === 0) { %>
          <p class="text-xs text-gray-500 py-4 text-center">No custom CMS web pages added yet.</p>
        <% } else { %>
          <div class="space-y-2.5">
            <% pages.forEach(pg => { %>
              <a href="/page/<%= pg.slug %>" class="flex items-center justify-between p-3.5 bg-[#0E0F10] hover:bg-gray-800 rounded-2xl border border-gray-800 hover:border-gray-700 transition group">
                <span class="text-xs font-bold text-gray-300 group-hover:text-white transition"><%= pg.title %></span>
                <svg class="w-4 h-4 text-gray-500 group-hover:text-brand-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Quick AI Diagnostic Sentinel Prompt -->
      <div class="bg-gradient-to-br from-[#18191C] to-purple-950 rounded-3xl border border-purple-500 border-opacity-30 p-7 shadow-2xl relative overflow-hidden">
        <div class="absolute -right-6 -bottom-6 text-7xl opacity-5">🤖</div>
        <h3 class="font-extrabold text-white text-base tracking-tight mb-2 flex items-center space-x-2">
          <span>🤖 Server Auto-Recovery AI</span>
        </h3>
        <p class="text-xs text-purple-200 text-opacity-80 mb-6 leading-relaxed">
          Have questions about game optimization, memory clamping, or EULA agreements? Our 24/7 AI Watchdog is ready to analyze your node.
        </p>
        <a href="/ai-assistant" class="block w-full py-3 bg-purple-600 hover:bg-purple-500 text-white text-center text-xs font-extrabold uppercase tracking-wider rounded-xl shadow-lg transition transform hover:scale-[1.02]">
          Prompt AI Assistant →
        </a>
      </div>

    </div>

  </div>

</div>

<%- include('partials/footer') %>
