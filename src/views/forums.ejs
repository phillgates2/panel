<%- include('partials/header', { title: 'Community Forums & Live Shoutbox' }) %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10" x-data="{
  chatBuffer: <%= JSON.stringify(chatMessages) %>,
  newChatMessage: ''
}" x-init="
  $nextTick(() => {
    const el = document.getElementById('forums-chat-box');
    if (el) el.scrollTop = el.scrollHeight;
  });

  if (typeof io !== 'undefined') {
    const socket = io();
    socket.emit('subscribe_forum_chat');
    socket.on('forum_chat', messageData => {
      chatBuffer.push(messageData);
      if (chatBuffer.length > 50) chatBuffer.shift();
      $nextTick(() => {
        const el = document.getElementById('forums-chat-box');
        if (el) el.scrollTop = el.scrollHeight;
      });
    });
  }
">

  <!-- Welcome Header -->
  <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-8 sm:p-10 shadow-2xl flex flex-col md:flex-row items-center justify-between gap-6 mb-10">
    <div class="flex items-center space-x-5">
      <div class="w-16 h-16 bg-[#5865F2] bg-opacity-10 text-[#5865F2] rounded-2xl border border-[#5865F2] border-opacity-20 flex items-center justify-center font-extrabold text-3xl shadow-inner">
        💬
      </div>
      <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">Community Forums & Live Hub</h1>
        <p class="text-xs text-gray-400 mt-1">Discuss game setups, share Pterodactyl yolk configurations, and chat live with fellow network gamers.</p>
      </div>
    </div>

    <div>
      <a href="/forums/new" class="px-8 py-4 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-sm rounded-2xl shadow-xl transition transform hover:scale-105 flex items-center space-x-2.5">
        <span>✍️ Create New Forum Topic</span>
      </a>
    </div>
  </div>

  <% if (error) { %>
    <div class="bg-red-500 bg-opacity-10 border border-red-500 border-opacity-20 text-red-400 p-4 rounded-2xl text-xs font-semibold mb-8 flex items-center space-x-3">
      <span>⚠️</span>
      <span><%= error %></span>
    </div>
  <% } %>

  <% if (success) { %>
    <div class="bg-green-500 bg-opacity-10 border border-green-500 border-opacity-20 text-green-400 p-4 rounded-2xl text-xs font-semibold mb-8 flex items-center space-x-3">
      <span>✅</span>
      <span><%= success %></span>
    </div>
  <% } %>

  <!-- Main Grid: Live Chat Feature (Full top or side) + Forum Categories -->
  
  <!-- REAL-TIME FORUMS LIVE CHAT BOX -->
  <div class="bg-[#18191C] rounded-3xl border border-gray-800 shadow-2xl overflow-hidden mb-12 flex flex-col h-[480px]">
    
    <div class="bg-[#141517] p-5 px-7 border-b border-gray-800 flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <span class="flex h-2.5 w-2.5 relative"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-500 opacity-75"></span><span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-brand-500"></span></span>
        <h3 class="font-extrabold text-white tracking-tight flex items-center space-x-1.5">
          <span>Live Community Forums Shoutbox</span>
        </h3>
      </div>
      <span class="text-[11px] font-bold text-gray-400">Public Live Stream</span>
    </div>

    <!-- Messages Container -->
    <div id="forums-chat-box" class="p-6 flex-grow overflow-y-auto bg-[#0E0F10] space-y-4">
      <template x-for="msg in chatBuffer" :key="msg.id">
        <div class="flex items-start space-x-3 hover:bg-gray-900 hover:bg-opacity-40 p-2 rounded-2xl transition">
          <img :src="msg.avatar || '/assets/default_avatar.png'" class="w-10 h-10 rounded-xl object-cover border border-gray-800 flex-shrink-0">
          <div class="space-y-1 min-w-0 flex-grow">
            <div class="flex items-center space-x-2">
              <span class="font-bold text-xs text-white truncate" x-text="msg.username"></span>
              <span x-show="msg.role === 'admin'" class="px-1.5 py-0.5 bg-brand-500 bg-opacity-10 text-brand-500 text-[9px] font-extrabold uppercase rounded">Admin</span>
              <span class="text-[10px] text-gray-500 font-mono" x-text="new Date(msg.created_at || Date.now()).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })"></span>
            </div>
            <p class="text-xs text-gray-300 leading-relaxed break-words" x-text="msg.message"></p>
          </div>
        </div>
      </template>
      <div x-show="chatBuffer.length === 0" class="text-gray-600 py-12 text-center italic text-xs">
        No chat messages posted yet. Be the first to greet the network!
      </div>
    </div>

    <!-- Input Box -->
    <div class="p-4 bg-[#141517] border-t border-gray-800">
      <% if (user) { %>
        <form @submit.prevent="
          if (!newChatMessage.trim()) return;
          const text = newChatMessage;
          newChatMessage = '';
          fetch('/api/forums/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: text })
          })
          .then(r => r.json())
          .then(data => {
            if (data.message) {
              // If websocket didn't instantly broadcast, append locally
              if (!chatBuffer.some(c => c.id === data.message.id)) {
                chatBuffer.push(data.message);
                $nextTick(() => {
                  const el = document.getElementById('forums-chat-box');
                  if (el) el.scrollTop = el.scrollHeight;
                });
              }
            }
          });
        " class="flex items-center space-x-3">
          <input type="text" x-model="newChatMessage" placeholder="Type a message to the live forums chat (Press Enter to send)..." maxlength="500" class="flex-grow bg-[#0E0F10] border border-gray-800 rounded-2xl px-5 py-3.5 text-white text-xs sm:text-sm focus:outline-none focus:border-brand-500 transition">
          <button type="submit" class="px-8 py-3.5 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-xs sm:text-sm rounded-2xl shadow-lg transition transform hover:scale-105 flex-shrink-0 flex items-center space-x-2">
            <span>Send Chat 🚀</span>
          </button>
        </form>
      <% } else { %>
        <div class="py-2 text-center text-xs text-gray-500">
          🔒 <a href="/login" class="text-brand-500 hover:underline font-extrabold">Sign in</a> to join the live forums discussion.
        </div>
      <% } %>
    </div>

  </div>

  <!-- FORUMS CATEGORIES & LATEST DISCUSSIONS GRID -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    
    <!-- Left 2 Cols: Structured Categories List -->
    <div class="lg:col-span-2 space-y-6">
      <div class="border-b border-gray-800 pb-4 flex items-center justify-between">
        <h2 class="text-2xl font-extrabold text-white tracking-tight flex items-center space-x-2.5">
          <span class="text-brand-500">🗂️</span>
          <span>Discussion Categories</span>
        </h2>
        <span class="text-xs font-bold text-gray-500"><%= categories.length %> Rooms</span>
      </div>

      <div class="space-y-4">
        <% categories.forEach(cat => { %>
          <a href="/forums/category/<%= cat.id %>" class="bg-[#18191C] rounded-3xl border border-gray-800 hover:border-brand-500 transition p-7 shadow-xl flex items-center justify-between group block">
            <div class="pr-4">
              <h3 class="text-xl font-extrabold text-white group-hover:text-brand-500 transition"><%= cat.name %></h3>
              <p class="text-xs text-gray-400 mt-2 leading-relaxed"><%= cat.description %></p>
            </div>

            <!-- Stats -->
            <div class="flex items-center space-x-6 flex-shrink-0 text-right pr-2">
              <div>
                <p class="text-base font-extrabold text-white font-mono"><%= cat.topic_count %></p>
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Topics</p>
              </div>

              <div>
                <p class="text-base font-extrabold text-brand-500 font-mono"><%= cat.reply_count %></p>
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Replies</p>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>

    <!-- Right 1 Col: Recent Topics Sidebar -->
    <div class="space-y-6">
      <div class="border-b border-gray-800 pb-4">
        <h3 class="text-xl font-extrabold text-white tracking-tight flex items-center space-x-2">
          <span class="text-amber-400">🔥</span>
          <span>Active Discussions</span>
        </h3>
      </div>

      <% if (recentTopics.length === 0) { %>
        <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-8 text-center text-xs text-gray-500">
          No topics initiated yet.
        </div>
      <% } else { %>
        <div class="space-y-3">
          <% recentTopics.forEach(top => { %>
            <a href="/forums/topic/<%= top.id %>" class="bg-[#18191C] rounded-2xl border border-gray-800 p-5 hover:border-gray-700 transition block group shadow">
              <div class="flex items-center justify-between text-[10px] font-extrabold uppercase text-brand-500 mb-1.5">
                <span><%= top.category_name %></span>
                <span class="text-gray-500 font-mono"><%= top.reply_count %> Replies</span>
              </div>
              <h4 class="text-sm font-extrabold text-white group-hover:text-brand-500 transition line-clamp-1"><%= top.title %></h4>
              <div class="flex items-center space-x-2 text-[11px] text-gray-400 mt-2">
                <img src="<%= top.author_avatar || '/assets/default_avatar.png' %>" class="w-4 h-4 rounded-full object-cover">
                <span><%= top.author_name %></span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

  </div>

</div>

<%- include('partials/footer') %>
