<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' + siteTitle : siteTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    code, pre { font-family: 'JetBrains Mono', monospace; }
  </style>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: { 500: '#5865F2', 600: '#4752C4' },
            dark: { 800: '#18191C', 900: '#0E0F10', 950: '#090A0B' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-[#0E0F10] text-gray-100 min-h-screen flex flex-col antialiased selection:bg-brand-500 selection:text-white">

  <!-- Top Global Navigation -->
  <header class="sticky top-0 z-50 bg-[#18191C] bg-opacity-95 backdrop-blur border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        
        <!-- Left: Brand Logo & Navigation -->
        <div class="flex items-center space-x-8">
          <a href="/" class="flex items-center space-x-3 group">
            <div class="w-10 h-10 bg-brand-500 rounded-xl flex items-center justify-center text-white font-extrabold text-xs shadow-lg group-hover:scale-105 transition transform">
              -OZ-
            </div>
            <div>
              <span class="font-extrabold text-lg text-white tracking-tight flex items-center space-x-1.5"><%= typeof siteTitle !== 'undefined' ? siteTitle : '-OZ- Panel Hub Enterprise' %></span>
              <span class="block text-[10px] text-brand-500 font-bold uppercase tracking-wider">Esports Hosting Core</span>
            </div>
          </a>

          <!-- Main Nav Links -->
          <nav class="hidden md:flex items-center space-x-1">
            <a href="/" class="px-3 py-2 rounded-xl text-xs font-semibold text-gray-300 hover:text-white hover:bg-gray-800 transition">CMS Home</a>
            <a href="/forums" class="px-3 py-2 rounded-xl text-xs font-semibold text-gray-300 hover:text-white hover:bg-gray-800 transition flex items-center space-x-1.5">
              <span>Forums & Live Chat</span>
              <span class="flex h-2 w-2 relative"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-500 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span></span>
            </a>
            <a href="/hardware" class="px-3 py-2 rounded-xl text-xs font-semibold text-green-400 hover:bg-green-500 hover:bg-opacity-10 transition flex items-center space-x-1">
              <span>🖥️ Hardware Telemetry</span>
            </a>
            <a href="/ai-assistant" class="px-3 py-2 rounded-xl text-xs font-semibold text-amber-400 hover:bg-amber-400 hover:bg-opacity-10 transition flex items-center space-x-1">
              <span>🤖 AI Sentinel</span>
            </a>
            <% if (typeof navLinks !== 'undefined') { %>
              <% navLinks.forEach(link => { %>
                <a href="<%= link.url %>" target="<%= link.target %>" class="px-3 py-2 rounded-xl text-xs font-semibold text-gray-300 hover:text-white hover:bg-gray-800 transition"><%= link.label %></a>
              <% }) %>
            <% } %>
          </nav>
        </div>

        <!-- Right: Auth / Quick Dashboard Actions -->
        <div class="flex items-center space-x-4">
          <% if (typeof user !== 'undefined' && user) { %>
            <!-- Active Server Status Button -->
            <a href="/dashboard" class="hidden sm:flex items-center space-x-2 px-4 py-2 bg-green-500 bg-opacity-10 rounded-xl border border-green-500 border-opacity-20 text-green-400 text-xs font-bold hover:bg-opacity-20 transition">
              <span class="h-2 w-2 bg-green-400 rounded-full animate-pulse"></span>
              <span>My Servers Room</span>
            </a>

            <!-- User Menu -->
            <div class="relative" x-data="{ open: false }">
              <button @click="open = !open" class="flex items-center space-x-3 p-1.5 rounded-xl hover:bg-gray-800 transition focus:outline-none">
                <img src="<%= user.avatar || '/assets/default_avatar.png' %>" class="w-8 h-8 rounded-lg object-cover border border-gray-700">
                <span class="hidden sm:block text-xs font-bold text-white"><%= user.username %></span>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </button>

              <!-- Dropdown -->
              <div x-show="open" @click.away="open = false" x-transition x-cloak class="absolute right-0 mt-2 w-56 bg-[#18191C] rounded-2xl border border-gray-800 shadow-2xl py-2 z-50">
                <div class="px-4 py-2 border-b border-gray-800 mb-1">
                  <p class="text-[10px] text-gray-400 uppercase font-semibold">Signed in as</p>
                  <p class="text-xs font-bold text-white truncate"><%= user.email %></p>
                  <span class="inline-block mt-1 px-2 py-0.5 bg-brand-500 bg-opacity-10 text-brand-500 text-[10px] font-extrabold uppercase rounded-md"><%= user.role %></span>
                </div>
                
                <a href="/dashboard" class="flex items-center space-x-2 px-4 py-2 text-xs font-semibold text-gray-300 hover:text-white hover:bg-gray-800 transition">
                  <span class="text-brand-500 font-bold">🎮</span>
                  <span>Game Servers</span>
                </a>

                <a href="/hardware" class="flex items-center space-x-2 px-4 py-2 text-xs font-semibold text-gray-300 hover:text-white hover:bg-gray-800 transition">
                  <span class="text-green-400 font-bold">🖥️</span>
                  <span>Hardware Telemetry</span>
                </a>
                
                <a href="/settings" class="flex items-center space-x-2 px-4 py-2 text-xs font-semibold text-gray-300 hover:text-white hover:bg-gray-800 transition">
                  <span class="text-gray-400 font-bold">⚙️</span>
                  <span>Advanced Settings & 2FA</span>
                </a>

                <% if (user.role === 'admin') { %>
                  <a href="/admin" class="flex items-center space-x-2 px-4 py-2 text-xs font-semibold text-purple-400 hover:bg-purple-500 hover:bg-opacity-10 transition">
                    <span class="font-bold">👑</span>
                    <span>Super Administrator CMS</span>
                  </a>
                <% } %>

                <div class="border-t border-gray-800 mt-1 pt-1">
                  <a href="/logout" class="flex items-center space-x-2 px-4 py-2 text-xs font-semibold text-red-400 hover:bg-red-500 hover:bg-opacity-10 transition">
                    <span class="font-bold">🛑</span>
                    <span>Sign Out</span>
                  </a>
                </div>
              </div>
            </div>

          <% } else { %>
            <a href="/login" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 rounded-xl text-xs font-bold text-white transition">Sign In</a>
            <a href="/register" class="px-4 py-2 bg-brand-500 hover:bg-brand-600 rounded-xl text-xs font-bold text-white shadow-lg transition">Register</a>
          <% } %>
        </div>

      </div>
    </div>
  </header>

  <!-- Main Active Container -->
  <main class="flex-grow">
