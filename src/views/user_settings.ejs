<%- include('partials/header', { title: 'Advanced User Allocations & Profile' }) %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10" x-data="{ activeTab: '<%= activeTab %>' }">

  <!-- Top Banner -->
  <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-8 sm:p-10 shadow-2xl flex flex-col md:flex-row items-center justify-between gap-6 mb-10">
    <div class="flex items-center space-x-5">
      <img src="<%= user.avatar || '/assets/default_avatar.png' %>" class="w-16 h-16 rounded-2xl object-cover border border-gray-700 shadow-xl flex-shrink-0">
      <div>
        <div class="flex items-center space-x-2">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight"><%= user.username %></h1>
          <span class="px-2.5 py-0.5 bg-brand-500 bg-opacity-10 text-brand-500 text-[10px] font-extrabold uppercase rounded-md"><%= user.role %></span>
        </div>
        <p class="text-xs text-gray-400 mt-1 font-mono"><%= user.email %></p>
      </div>
    </div>

    <div>
      <span class="px-4 py-2 bg-[#0E0F10] rounded-2xl border border-gray-800 text-xs font-mono text-gray-400 flex items-center space-x-2 shadow">
        <span>Active Account ID:</span>
        <code class="text-green-400 font-bold">#<%= user.id %></code>
      </span>
    </div>
  </div>

  <% if (error) { %>
    <div class="bg-red-500 bg-opacity-10 border border-red-500 border-opacity-20 text-red-400 p-4 rounded-2xl text-xs font-semibold mb-8 flex items-center space-x-3">
      <span>⚠️</span>
      <span><%= error %></span>
    </div>
  <% } %>

  <% if (success) { %>
    <div class="bg-green-500 bg-opacity-10 border border-green-500 border-opacity-20 text-green-400 p-4 rounded-2xl text-xs font-semibold mb-8 flex items-center space-x-3">
      <span>✅</span>
      <span><%= success %></span>
    </div>
  <% } %>

  <!-- Tab Nav Strip -->
  <div class="flex items-center space-x-3 border-b border-gray-800 pb-4 mb-8 overflow-x-auto">
    <button @click="activeTab = 'profile'" :class="activeTab === 'profile' ? 'bg-[#5865F2] text-white font-extrabold shadow-lg' : 'bg-[#18191C] text-gray-400 hover:text-white hover:bg-gray-800'" class="px-5 py-3 rounded-2xl text-xs uppercase tracking-wider transition flex items-center space-x-2 whitespace-nowrap border border-gray-800">
      <span>👤 General Profile</span>
    </button>
    
    <button @click="activeTab = 'security'" :class="activeTab === 'security' ? 'bg-[#5865F2] text-white font-extrabold shadow-lg' : 'bg-[#18191C] text-gray-400 hover:text-white hover:bg-gray-800'" class="px-5 py-3 rounded-2xl text-xs uppercase tracking-wider transition flex items-center space-x-2 whitespace-nowrap border border-gray-800">
      <span>🔒 Security & 2FA</span>
    </button>

    <button @click="activeTab = 'sftp'" :class="activeTab === 'sftp' ? 'bg-[#5865F2] text-white font-extrabold shadow-lg' : 'bg-[#18191C] text-gray-400 hover:text-white hover:bg-gray-800'" class="px-5 py-3 rounded-2xl text-xs uppercase tracking-wider transition flex items-center space-x-2 whitespace-nowrap border border-gray-800">
      <span>🔌 Standalone SFTP</span>
    </button>

    <button @click="activeTab = 'api'" :class="activeTab === 'api' ? 'bg-[#5865F2] text-white font-extrabold shadow-lg' : 'bg-[#18191C] text-gray-400 hover:text-white hover:bg-gray-800'" class="px-5 py-3 rounded-2xl text-xs uppercase tracking-wider transition flex items-center space-x-2 whitespace-nowrap border border-gray-800">
      <span>🔑 Enterprise API Key</span>
    </button>

    <button @click="activeTab = 'audit'" :class="activeTab === 'audit' ? 'bg-[#5865F2] text-white font-extrabold shadow-lg' : 'bg-[#18191C] text-gray-400 hover:text-white hover:bg-gray-800'" class="px-5 py-3 rounded-2xl text-xs uppercase tracking-wider transition flex items-center space-x-2 whitespace-nowrap border border-gray-800">
      <span>📜 Action Audit Logs</span>
    </button>
  </div>

  <!-- TAB 1: Profile -->
  <div x-show="activeTab === 'profile'" x-transition.opacity>
    <div class="max-w-3xl bg-[#18191C] rounded-3xl border border-gray-800 shadow-2xl p-8 sm:p-12 space-y-8">
      <div>
        <h2 class="text-2xl font-extrabold text-white tracking-tight">Public Community Identity</h2>
        <p class="text-xs text-gray-400 mt-1">Displayed in news articles and forum discussion topics.</p>
      </div>

      <form action="/settings/profile" method="POST" class="space-y-6">
        <div>
          <label class="block text-xs font-bold text-gray-300 uppercase tracking-wider mb-2">Avatar URL</label>
          <input type="url" name="avatar" value="<%= user.avatar %>" placeholder="https://example.com/my_avatar.png" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl px-5 py-4 text-white text-sm focus:outline-none focus:border-brand-500 transition font-mono">
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-300 uppercase tracking-wider mb-2">Personal Biography / Tagline</label>
          <textarea name="bio" rows="4" placeholder="Tell the community about your gaming history..." required class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl p-5 text-white text-sm focus:outline-none focus:border-brand-500 transition resize-none leading-relaxed"><%= user.bio %></textarea>
        </div>

        <div class="pt-4 border-t border-gray-800 flex justify-end">
          <button type="submit" class="px-8 py-4 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-sm rounded-2xl shadow-xl transition transform hover:scale-105">
            💾 Save Profile Identity
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- TAB 2: Security & 2FA -->
  <div x-show="activeTab === 'security'" x-transition.opacity x-cloak>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Change Master Password -->
      <div class="bg-[#18191C] rounded-3xl border border-gray-800 shadow-2xl p-8 sm:p-12 space-y-8">
        <div>
          <h2 class="text-2xl font-extrabold text-white tracking-tight">Master Authentication Password</h2>
          <p class="text-xs text-gray-400 mt-1">Used to access this website dashboard and complete CMS pages.</p>
        </div>

        <form action="/settings/password" method="POST" class="space-y-5">
          <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Current Password</label>
            <input type="password" name="password_old" placeholder="••••••••••••" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl px-5 py-4 text-white text-sm focus:outline-none focus:border-brand-500 transition">
          </div>

          <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">New Password</label>
            <input type="password" name="password_new" placeholder="Min 8 characters..." required class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl px-5 py-4 text-white text-sm focus:outline-none focus:border-brand-500 transition">
          </div>

          <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Confirm New Password</label>
            <input type="password" name="password_confirm" placeholder="Confirm your new password..." required class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl px-5 py-4 text-white text-sm focus:outline-none focus:border-brand-500 transition">
          </div>

          <div class="pt-4 border-t border-gray-800 flex justify-end">
            <button type="submit" class="px-8 py-4 bg-amber-600 hover:bg-amber-500 font-extrabold text-white text-sm rounded-2xl shadow-xl transition transform hover:scale-105">
              🛡️ Update Password
            </button>
          </div>
        </form>
      </div>

      <!-- Toggle 2FA -->
      <div class="bg-[#18191C] rounded-3xl border border-gray-800 shadow-2xl p-8 sm:p-12 space-y-8 flex flex-col justify-between">
        <div>
          <div>
            <div class="w-14 h-14 bg-[#FEE75C] bg-opacity-10 text-[#FEE75C] rounded-2xl border border-[#FEE75C] border-opacity-20 flex items-center justify-center font-bold text-2xl mb-4">
              🛡️
            </div>
            <h2 class="text-2xl font-extrabold text-white tracking-tight">Two-Factor Authentication (2FA)</h2>
            <p class="text-xs text-gray-400 mt-1 leading-relaxed">Protect your Master account and sandboxed Game Server containers from unauthorized login by enforcing Time-Based One-Time Passwords (TOTP).</p>
          </div>

          <div class="mt-8 p-6 bg-[#0E0F10] rounded-2xl border border-gray-800 flex items-center justify-between shadow">
            <div>
              <p class="text-xs font-extrabold text-white uppercase tracking-wider">Status</p>
              <p class="text-sm font-bold mt-1 <%= user.two_factor_enabled ? 'text-green-400' : 'text-red-400' %>">
                <%= user.two_factor_enabled ? '🟢 Enabled / Active' : '🔴 Disabled' %>
              </p>
            </div>

            <form action="/settings/toggle-2fa" method="POST">
              <button type="submit" class="px-6 py-3.5 <%= user.two_factor_enabled ? 'bg-red-600 hover:bg-red-500' : 'bg-green-600 hover:bg-green-500' %> font-extrabold text-white text-xs uppercase tracking-wider rounded-xl transition shadow">
                <%= user.two_factor_enabled ? 'Disable 2FA' : 'Activate 2FA' %>
              </button>
            </form>
          </div>

          <% if (user.two_factor_enabled && user.two_factor_secret) { %>
            <div class="mt-8 p-6 bg-amber-500 bg-opacity-10 border border-amber-500 border-opacity-30 rounded-2xl space-y-3">
              <h4 class="text-xs font-extrabold uppercase tracking-wider text-amber-400">Your Master Secret Token</h4>
              <p class="text-xs text-gray-300">Input this unique code into **Google Authenticator** or **Authy**:</p>
              <code class="block bg-[#0E0F10] p-4 rounded-xl border border-gray-800 text-center font-mono font-bold text-2xl text-white tracking-widest"><%= user.two_factor_secret %></code>
            </div>
          <% } %>
        </div>

        <div class="border-t border-gray-800 pt-6 text-xs text-gray-500 text-center">
          Enterprise Security Clamping Sentinel
        </div>
      </div>

    </div>
  </div>

  <!-- TAB 3: SFTP Standalone Password -->
  <div x-show="activeTab === 'sftp'" x-transition.opacity x-cloak>
    <div class="max-w-2xl bg-[#18191C] rounded-3xl border border-gray-800 shadow-2xl p-8 sm:p-12 space-y-8">
      <div>
        <div class="w-14 h-14 bg-brand-500 bg-opacity-10 text-brand-500 rounded-2xl border border-brand-500 border-opacity-20 flex items-center justify-center font-bold text-2xl mb-4">
          🔌
        </div>
        <h2 class="text-2xl font-extrabold text-white tracking-tight">Standalone SFTP Direct Connection Password</h2>
        <p class="text-xs text-gray-400 mt-1 leading-relaxed">Configure a separate high-security password used exclusively for connecting external FTP/SFTP clients (like FileZilla or WinSCP) to your sandboxed server directories.</p>
      </div>

      <form action="/settings/sftp-password" method="POST" class="space-y-6">
        <div>
          <label class="block text-xs font-bold text-gray-300 uppercase tracking-wider mb-2">Dedicated SFTP Password</label>
          <input type="password" name="sftp_password" placeholder="Create a standalone SFTP connection password..." required class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl px-5 py-4 text-white text-sm focus:outline-none focus:border-brand-500 transition">
        </div>

        <div class="pt-4 border-t border-gray-800 flex items-center justify-between">
          <span class="text-xs text-gray-500">Listening on Master Embedded Port <code class="text-green-400">2022</code></span>
          <button type="submit" class="px-8 py-4 bg-green-600 hover:bg-green-500 font-extrabold text-white text-sm rounded-2xl shadow-xl transition transform hover:scale-105">
            💾 Update SFTP Credentials
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- TAB 4: API Keys -->
  <div x-show="activeTab === 'api'" x-transition.opacity x-cloak>
    <div class="max-w-3xl bg-[#18191C] rounded-3xl border border-gray-800 shadow-2xl p-8 sm:p-12 space-y-8">
      <div>
        <h2 class="text-2xl font-extrabold text-white tracking-tight">Enterprise API Access Token</h2>
        <p class="text-xs text-gray-400 mt-1">Authenticate external tools, discord bots, or automated Caddy proxy scripts to interact with your hosting account.</p>
      </div>

      <div class="p-7 bg-[#0E0F10] rounded-2xl border border-gray-800 space-y-4 shadow">
        <div>
          <p class="text-xs font-extrabold uppercase tracking-wider text-gray-500 mb-1">Your Active Secret Token</p>
          <code class="block bg-[#18191C] p-5 rounded-2xl border border-gray-800 text-purple-400 font-mono text-sm break-all font-bold select-all">
            <%= user.api_key || 'No API Key generated yet. Click below to instantiate.' %>
          </code>
        </div>

        <form action="/settings/api-key" method="POST" class="pt-4 border-t border-gray-800/80 flex justify-end">
          <button type="submit" class="px-8 py-4 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-sm rounded-2xl shadow-xl transition transform hover:scale-105 flex items-center space-x-2">
            <span>⚡ Generate New API Token</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- TAB 5: Audit Logs -->
  <div x-show="activeTab === 'audit'" x-transition.opacity x-cloak>
    <div class="bg-[#18191C] rounded-3xl border border-gray-800 shadow-2xl p-8 sm:p-12 space-y-6">
      <div class="border-b border-gray-800 pb-4 flex items-center justify-between">
        <h2 class="text-2xl font-extrabold text-white tracking-tight">Action Audit Logs Sentinel</h2>
        <span class="text-xs font-mono text-gray-500"><%= auditLogs.length %> Logged Operations</span>
      </div>

      <% if (auditLogs.length === 0) { %>
        <div class="py-12 text-center text-gray-600 italic text-sm">No operations recorded yet.</div>
      <% } else { %>
        <div class="space-y-3 overflow-y-auto max-h-[500px] pr-2">
          <% auditLogs.forEach(lg => { %>
            <div class="p-4 bg-[#0E0F10] rounded-2xl border border-gray-800 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 hover:border-gray-700 transition font-mono">
              <div>
                <span class="px-2.5 py-1 bg-brand-500 bg-opacity-10 text-brand-500 font-extrabold text-[10px] uppercase rounded-lg mr-2"><%= lg.action %></span>
                <span class="text-white text-xs font-bold"><%= lg.details || 'Operation executed.' %></span>
              </div>
              <div class="flex items-center space-x-4 text-xs text-gray-500 flex-shrink-0">
                <code><%= lg.ip_address %></code>
                <span>•</span>
                <span><%= new Date(lg.created_at).toLocaleString() %></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
