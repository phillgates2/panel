<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>-OZ- Panel Hub - Community Account Registration</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
  </style>
</head>
<body class="bg-[#0E0F10] text-gray-100 min-h-screen flex items-center justify-center p-4">

  <div class="max-w-md w-full bg-[#18191C] rounded-2xl border border-gray-800 p-8 shadow-2xl">
    
    <div class="text-center mb-8">
      <div class="w-14 h-14 bg-green-500 bg-opacity-10 text-green-400 rounded-2xl border border-green-500 border-opacity-20 flex items-center justify-center font-extrabold text-xl mx-auto mb-4">
        -OZ-
      </div>
      <h1 class="text-2xl font-bold text-white tracking-tight">Create an Account</h1>
      <p class="text-xs text-gray-400 mt-1">Join the ultimate -OZ- Panel Hub Enterprise Network</p>
    </div>

    <% if (error) { %>
      <div class="bg-red-500 bg-opacity-10 border border-red-500 border-opacity-20 text-red-400 p-3 rounded-xl text-xs font-medium mb-6 text-center">
        <%= error %>
      </div>
    <% } %>

    <form action="/register" method="POST" class="space-y-4">
      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Username</label>
        <input type="text" name="username" placeholder="GamerHero2026" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-[#5865F2] transition">
      </div>

      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Email Address</label>
        <input type="email" name="email" placeholder="hero@oz-esports.network" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-[#5865F2] transition">
      </div>

      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Password</label>
        <input type="password" name="password" placeholder="Min 8 characters..." required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-[#5865F2] transition">
      </div>

      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Confirm Password</label>
        <input type="password" name="password_confirm" placeholder="Confirm your password..." required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-[#5865F2] transition">
      </div>

      <button type="submit" class="w-full py-3.5 bg-green-600 hover:bg-green-500 font-bold text-white text-sm rounded-xl shadow-lg transition transform hover:scale-[1.01] mt-2">
        ✨ Verify & Register Account
      </button>
    </form>

    <div class="mt-8 text-center border-t border-gray-800 pt-6">
      <p class="text-xs text-gray-500">Already have an account? <a href="/login" class="text-[#5865F2] hover:underline font-semibold">Sign in here</a></p>
    </div>

  </div>

</body>
</html>
