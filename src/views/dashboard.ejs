<%- include('partials/header', { title: 'Game Servers Control Room' }) %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10" x-data="{ openCreateModal: false, selectedEgg: null, eggsData: <%= JSON.stringify(eggs) %> }">

  <!-- Top Welcome & Deploy Header -->
  <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-8 sm:p-10 shadow-2xl flex flex-col md:flex-row items-center justify-between gap-6 mb-10">
    <div class="flex items-center space-x-5">
      <div class="w-16 h-16 bg-[#5865F2] bg-opacity-10 text-[#5865F2] rounded-2xl border border-[#5865F2] border-opacity-20 flex items-center justify-center font-extrabold text-2xl shadow-inner">
        🎮
      </div>
      <div>
        <div class="flex items-center space-x-2">
          <h1 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">My Game Servers</h1>
          <span class="px-2.5 py-0.5 bg-brand-500 bg-opacity-10 text-brand-500 text-[10px] font-extrabold uppercase rounded-md"><%= user.role %></span>
        </div>
        <p class="text-xs text-gray-400 mt-1">Manage process eggs, launch SFTP consoles, and attach automated Discord webhooks.</p>
      </div>
    </div>

    <!-- Quick Stat Badges & Create Trigger -->
    <div class="flex items-center space-x-4 w-full md:w-auto justify-end">
      <div class="hidden sm:block text-right pr-4 border-r border-gray-800">
        <p class="text-[10px] uppercase font-bold text-gray-500">Active Allocations</p>
        <p class="text-sm font-extrabold text-green-400 font-mono"><%= servers.filter(s => s.status === 'online').length %> / <%= servers.length %> Online</p>
      </div>

      <button @click="openCreateModal = true" class="px-6 py-4 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-sm rounded-2xl shadow-xl transition transform hover:scale-105 flex items-center space-x-2.5 flex-grow md:flex-grow-0 justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
        <span>⚡ Deploy New Game Server</span>
      </button>
    </div>
  </div>

  <% if (error) { %>
    <div class="bg-red-500 bg-opacity-10 border border-red-500 border-opacity-20 text-red-400 p-4 rounded-2xl text-xs font-semibold mb-8 flex items-center space-x-3">
      <span>⚠️</span>
      <span><%= error %></span>
    </div>
  <% } %>

  <% if (success) { %>
    <div class="bg-green-500 bg-opacity-10 border border-green-500 border-opacity-20 text-green-400 p-4 rounded-2xl text-xs font-semibold mb-8 flex items-center space-x-3">
      <span>✅</span>
      <span><%= success %></span>
    </div>
  <% } %>

  <!-- Server Roster Grid -->
  <% if (servers.length === 0) { %>
    <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-16 text-center text-gray-500 shadow-2xl">
      <div class="text-6xl mb-4">🛸</div>
      <h3 class="text-xl font-bold text-white tracking-tight mb-2">No Game Servers Deployed</h3>
      <p class="text-xs text-gray-400 max-w-md mx-auto mb-8 leading-relaxed">You have not initialized any sandboxed game servers. Click the button below to instantiate your first Node, Minecraft, CS:GO, or Rust server.</p>
      <button @click="openCreateModal = true" class="px-8 py-4 bg-green-600 hover:bg-green-500 font-extrabold text-white text-sm rounded-2xl shadow-xl transition transform hover:scale-105">
        ⚡ Power On Your First Server
      </button>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% servers.forEach(srv => { %>
        <div class="bg-[#18191C] rounded-3xl border border-gray-800 hover:border-gray-700 transition shadow-xl overflow-hidden flex flex-col justify-between group">
          
          <!-- Card Top: Title, Status Badge & Egg -->
          <div class="p-7 border-b border-gray-800 bg-[#141517]">
            <div class="flex items-start justify-between">
              <div class="pr-3">
                <span class="text-[10px] font-extrabold uppercase tracking-wider text-brand-500 flex items-center space-x-1">
                  <span><%= srv.egg_name %></span>
                </span>
                <h3 class="text-xl font-extrabold text-white truncate mt-1 group-hover:text-brand-500 transition"><%= srv.name %></h3>
                <p class="text-xs font-mono text-gray-400 mt-1 flex items-center space-x-1.5">
                  <span class="text-gray-500">🔌 Connection:</span>
                  <code class="text-white bg-gray-800 px-2 py-0.5 rounded-md"><%= srv.ip %>:<%= srv.port %></code>
                </p>
              </div>

              <!-- Status Flag -->
              <div class="flex-shrink-0">
                <% if (srv.status === 'online') { %>
                  <span class="inline-flex items-center space-x-1.5 px-3 py-1 bg-green-500 bg-opacity-10 text-green-400 text-xs font-extrabold uppercase tracking-wider rounded-xl border border-green-500 border-opacity-20 animate-pulse">
                    <span class="h-2 w-2 bg-green-400 rounded-full"></span>
                    <span>Online</span>
                  </span>
                <% } else if (srv.status === 'starting') { %>
                  <span class="inline-flex items-center space-x-1.5 px-3 py-1 bg-amber-500 bg-opacity-10 text-amber-400 text-xs font-extrabold uppercase tracking-wider rounded-xl border border-amber-500 border-opacity-20">
                    <span class="h-2 w-2 bg-amber-400 rounded-full animate-ping"></span>
                    <span>Starting</span>
                  </span>
                <% } else if (srv.status === 'crashed') { %>
                  <span class="inline-flex items-center space-x-1.5 px-3 py-1 bg-red-500 bg-opacity-10 text-red-400 text-xs font-extrabold uppercase tracking-wider rounded-xl border border-red-500 border-opacity-20">
                    <span class="h-2 w-2 bg-red-400 rounded-full"></span>
                    <span>Crashed</span>
                  </span>
                <% } else if (srv.status === 'installing') { %>
                  <span class="inline-flex items-center space-x-1.5 px-3 py-1 bg-purple-500 bg-opacity-10 text-purple-400 text-xs font-extrabold uppercase tracking-wider rounded-xl border border-purple-500 border-opacity-20">
                    <svg class="w-3 h-3 animate-spin text-purple-400" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                    <span>Installing</span>
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center space-x-1.5 px-3 py-1 bg-gray-800 text-gray-400 text-xs font-extrabold uppercase tracking-wider rounded-xl border border-gray-700">
                    <span class="h-2 w-2 bg-gray-500 rounded-full"></span>
                    <span>Offline</span>
                  </span>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Card Middle: Live RAM / CPU Buffer Allocation Gauges -->
          <div class="p-7 flex-grow space-y-4">
            <div>
              <div class="flex justify-between text-xs font-bold mb-1.5">
                <span class="text-gray-400 flex items-center space-x-1"><span>🧠 Memory Pool</span></span>
                <span class="text-white font-mono"><%= srv.runtime ? srv.runtime.memory : '0' %> MB / <%= srv.memory_limit %> MB</span>
              </div>
              <div class="w-full bg-gray-800 h-2.5 rounded-full overflow-hidden">
                <div class="bg-brand-500 h-full transition-all duration-1000" style="width: <%= srv.runtime ? Math.min(100, Math.floor((srv.runtime.memory / srv.memory_limit) * 100)) : 0 %>%"></div>
              </div>
            </div>

            <div>
              <div class="flex justify-between text-xs font-bold mb-1.5">
                <span class="text-gray-400 flex items-center space-x-1"><span>⚡ Core Usage</span></span>
                <span class="text-white font-mono"><%= srv.runtime ? srv.runtime.cpu : '0.0' %> %</span>
              </div>
              <div class="w-full bg-gray-800 h-2.5 rounded-full overflow-hidden">
                <div class="bg-green-500 h-full transition-all duration-1000" style="width: <%= srv.runtime ? Math.min(100, Math.floor(parseFloat(srv.runtime.cpu) * 5)) : 0 %>%"></div>
              </div>
            </div>
          </div>

          <!-- Card Bottom Actions -->
          <div class="p-7 pt-0 flex items-center space-x-3">
            <a href="/servers/<%= srv.uuid %>" class="w-full py-3.5 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-xs text-center uppercase tracking-wider rounded-2xl shadow-lg transition transform hover:scale-[1.02]">
              ⚙️ Manage Console Suite →
            </a>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Modal: Deploy New Server Yolk Wizard -->
  <div x-show="openCreateModal" @click.away="openCreateModal = false" x-transition x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black bg-opacity-80 backdrop-blur-sm overflow-y-auto">
    <div class="max-w-2xl w-full bg-[#18191C] border border-gray-800 rounded-3xl shadow-2xl overflow-hidden my-8" @click.stop>
      
      <!-- Modal Header -->
      <div class="bg-[#141517] border-b border-gray-800 p-6 sm:p-8 flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="p-2.5 bg-brand-500 bg-opacity-10 text-brand-500 rounded-xl">⚡</div>
          <div>
            <h3 class="text-xl font-bold text-white tracking-tight">Deploy Pterodactyl Game Egg</h3>
            <p class="text-xs text-gray-400">Instantiate a sandboxed game environment and config yoke</p>
          </div>
        </div>
        <button @click="openCreateModal = false" class="text-gray-400 hover:text-white p-2 rounded-xl bg-gray-800 hover:bg-gray-700 transition">
          ✕
        </button>
      </div>

      <!-- Creation Wizard Form -->
      <form action="/servers/create" method="POST" class="p-6 sm:p-8 space-y-6">
        
        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Server Label / Title</label>
          <input type="text" name="name" placeholder="e.g. Community CS:GO Main Match #1" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-brand-500 transition">
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Network Port Binding</label>
            <input type="number" name="port" value="<%= Math.floor(Math.random() * 5000) + 25000 %>" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 font-mono text-white text-sm focus:outline-none focus:border-brand-500 transition">
          </div>

          <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Memory Allocation (MB)</label>
            <input type="number" name="memory_limit" value="2048" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 font-mono text-white text-sm focus:outline-none focus:border-brand-500 transition">
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Automated Discord Webhook URL (Optional)</label>
          <input type="url" name="discord_webhook" placeholder="https://discord.com/api/webhooks/..." class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-brand-500 transition">
          <p class="text-[11px] text-gray-500 mt-1">Sends an automated embedded Discord alert when created, started, or auto-recovered by AI.</p>
        </div>

        <!-- Select Game Egg Yolk -->
        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Select Game Yoke / Egg</label>
          <select name="egg_id" x-model="selectedEgg" @change="selectedEgg = $event.target.value" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-brand-500 transition">
            <option value="" disabled selected>-- Select an Egg Specification --</option>
            <template x-for="egg in eggsData" :key="egg.id">
              <option :value="egg.id" x-text="`${egg.nest_name} > ${egg.name}`"></option>
            </template>
          </select>
        </div>

        <!-- Dynamic Environment Variables matching the Egg -->
        <div x-show="selectedEgg" class="bg-[#0E0F10] rounded-2xl border border-gray-800 p-6 space-y-4">
          <h4 class="text-xs font-extrabold uppercase tracking-wider text-brand-500 mb-2">Yolk Runtime Configurations</h4>
          
          <template x-for="egg in eggsData.filter(e => e.id == selectedEgg)" :key="egg.id">
            <div>
              <p class="text-xs text-gray-400 mb-4" x-text="egg.description"></p>

              <template x-for="varItem in (typeof egg.env_variables === 'string' ? JSON.parse(egg.env_variables) : egg.env_variables)" :key="varItem.key">
                <div class="mb-4">
                  <label class="block text-[11px] font-bold text-gray-300 uppercase tracking-wider mb-1.5" x-text="varItem.label"></label>
                  <input type="text" :name="`env_${varItem.key}`" :value="varItem.default_value" class="w-full bg-[#18191C] border border-gray-800 rounded-xl px-3.5 py-2.5 font-mono text-white text-xs focus:outline-none focus:border-brand-500 transition">
                </div>
              </template>
            </div>
          </template>
        </div>

        <div class="pt-4 border-t border-gray-800 flex items-center justify-end space-x-4">
          <button type="button" @click="openCreateModal = false" class="px-6 py-3.5 bg-gray-800 hover:bg-gray-700 font-semibold text-white text-sm rounded-xl transition">Cancel</button>
          <button type="submit" class="px-8 py-3.5 bg-green-600 hover:bg-green-500 font-extrabold text-white text-sm rounded-xl shadow-xl transition transform hover:scale-105 flex items-center space-x-2">
            <span>⚡ Deploy Sandbox Container</span>
          </button>
        </div>

      </form>

    </div>
  </div>

</div>

<%- include('partials/footer') %>
