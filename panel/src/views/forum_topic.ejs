<%- include('partials/header', { title: topic.title }) %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Breadcrumbs Bar -->
  <div class="flex items-center space-x-2 font-mono text-xs bg-[#18191C] px-5 py-3 rounded-2xl border border-gray-800 mb-8">
    <a href="/forums" class="text-[#5865F2] hover:underline font-extrabold">Forums Hub</a>
    <span class="text-gray-600">/</span>
    <a href="/forums/category/<%= topic.category_id %>" class="text-gray-400 hover:text-white font-bold"><<%= topic.category_name %>></a>
    <span class="text-gray-600">/</span>
    <span class="text-white font-mono truncate"><%= topic.title %></span>
  </div>

  <% if (success) { %>
    <div class="bg-green-500 bg-opacity-10 border border-green-500 border-opacity-20 text-green-400 p-4 rounded-2xl text-xs font-semibold mb-8">
      ✅ <%= success %>
    </div>
  <% } %>

  <!-- OP Original Post Card -->
  <div class="bg-[#18191C] rounded-3xl border <%= topic.is_pinned ? 'border-amber-500/40 shadow-amber-500/5' : 'border-gray-800' %> shadow-2xl p-8 sm:p-12 mb-8">
    
    <!-- Topic Title -->
    <div class="border-b border-gray-800 pb-8 mb-8 flex items-start justify-between">
      <div>
        <div class="flex items-center space-x-2 mb-2">
          <% if (topic.is_pinned) { %>
            <span class="px-2.5 py-1 bg-amber-500 bg-opacity-10 text-amber-400 text-[10px] font-extrabold uppercase rounded-lg">📌 Pinned</span>
          <% } %>
          <span class="text-[11px] text-gray-400 font-mono"><%= new Date(topic.created_at).toLocaleString() %></span>
        </div>
        <h1 class="text-2xl sm:text-4xl font-extrabold text-white tracking-tight leading-snug"><%= topic.title %></h1>
      </div>
    </div>

    <!-- Author Profile Sidebar Layout -->
    <div class="flex flex-col sm:flex-row items-start gap-8">
      
      <!-- Left: Author Badge -->
      <div class="sm:w-48 flex-shrink-0 bg-[#0E0F10] p-5 rounded-2xl border border-gray-800 text-center w-full sm:w-auto">
        <img src="<%= topic.author_avatar || '/assets/default_avatar.png' %>" class="w-16 h-16 rounded-2xl object-cover mx-auto border border-gray-700 shadow-lg mb-3">
        <p class="font-extrabold text-white text-sm"><%= topic.author_name %></p>
        <span class="inline-block mt-1 px-2.5 py-0.5 bg-brand-500 bg-opacity-10 text-brand-500 text-[10px] font-extrabold uppercase rounded-md"><%= topic.author_role %></span>
      </div>

      <!-- Right: Content Body -->
      <div class="flex-grow min-w-0 prose prose-invert max-w-none text-gray-200 leading-relaxed text-base sm:text-lg">
        <%- topic.content.replace(/\n/g, '<br>') %>
      </div>

    </div>

  </div>

  <!-- Replies List Container -->
  <div class="space-y-6 mb-12">
    <h3 class="text-xl font-extrabold text-white tracking-tight flex items-center space-x-2">
      <span>💬 Community Replies</span>
      <span class="text-xs font-mono text-gray-500 bg-[#18191C] px-3 py-1 rounded-full border border-gray-800"><%= replies.length %></span>
    </h3>

    <% if (replies.length === 0) { %>
      <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-12 text-center text-gray-500 text-sm">
        No comments posted yet. Be the first to chime in below!
      </div>
    <% } else { %>
      <% replies.forEach((rep, idx) => { %>
        <div class="bg-[#18191C] rounded-3xl border border-gray-800 shadow-xl p-7 sm:p-9 flex flex-col sm:flex-row items-start gap-7">
          
          <!-- Reply Author -->
          <div class="sm:w-40 flex-shrink-0 bg-[#0E0F10] p-4 rounded-2xl border border-gray-800 text-center w-full sm:w-auto">
            <img src="<%= rep.reply_avatar || '/assets/default_avatar.png' %>" class="w-12 h-12 rounded-xl object-cover mx-auto border border-gray-700 mb-2">
            <p class="font-bold text-white text-xs truncate"><%= rep.reply_author %></p>
            <span class="inline-block mt-1 px-2 py-0.5 bg-gray-800 text-gray-400 text-[9px] font-extrabold uppercase rounded"><%= rep.reply_role %></span>
          </div>

          <!-- Reply Content Body -->
          <div class="flex-grow min-w-0 space-y-4">
            <div class="flex justify-between items-center text-[11px] font-mono text-gray-500 border-b border-gray-800/60 pb-2">
              <span>Comment #<%= idx + 1 %></span>
              <span><%= new Date(rep.created_at).toLocaleString() %></span>
            </div>
            <div class="prose prose-invert max-w-none text-gray-300 text-sm sm:text-base leading-relaxed">
              <%- rep.content.replace(/\n/g, '<br>') %>
            </div>
          </div>

        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Write New Reply Box -->
  <% if (user) { %>
    <div class="bg-[#18191C] rounded-3xl border border-gray-800 shadow-2xl p-8 sm:p-10">
      <h3 class="text-xl font-extrabold text-white tracking-tight mb-2 flex items-center space-x-2"><span>✍️ Post a Reply</span></h3>
      <p class="text-xs text-gray-400 mb-6">Contribute to the troubleshooting or community discussion.</p>

      <form action="/forums/topic/<%= topic.id %>/reply" method="POST" class="space-y-6">
        <div>
          <textarea name="content" rows="5" required placeholder="Write your reply here..." class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl p-5 text-white text-sm focus:outline-none focus:border-[#5865F2] transition resize-none leading-relaxed"></textarea>
        </div>

        <div class="flex justify-end">
          <button type="submit" class="px-8 py-4 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-sm rounded-2xl shadow-xl transition transform hover:scale-105">
            🚀 Submit Comment
          </button>
        </div>
      </form>
    </div>
  <% } else { %>
    <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-8 text-center text-xs text-gray-400">
      🔒 <a href="/login" class="text-[#5865F2] hover:underline font-extrabold">Authenticate</a> to leave a comment on this discussion.
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
