<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>-OZ- Panel Hub - Secure Portal Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
  </style>
</head>
<body class="bg-[#0E0F10] text-gray-100 min-h-screen flex items-center justify-center p-4">

  <div class="max-w-md w-full bg-[#18191C] rounded-2xl border border-gray-800 p-8 shadow-2xl">
    
    <div class="text-center mb-8">
      <div class="w-14 h-14 bg-[#5865F2] bg-opacity-10 text-[#5865F2] rounded-2xl border border-[#5865F2] border-opacity-20 flex items-center justify-center font-extrabold text-xl mx-auto mb-4">
        -OZ-
      </div>
      <h1 class="text-2xl font-bold text-white tracking-tight">-OZ- Panel Hub Login</h1>
      <p class="text-xs text-gray-400 mt-1">Authenticate to orchestrate your Sandboxed Game Servers</p>
    </div>

    <% if (error) { %>
      <div class="bg-red-500 bg-opacity-10 border border-red-500 border-opacity-20 text-red-400 p-3 rounded-xl text-xs font-medium mb-6 text-center">
        <%= error %>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="bg-green-500 bg-opacity-10 border border-green-500 border-opacity-20 text-green-400 p-3 rounded-xl text-xs font-medium mb-6 text-center">
        <%= success %>
      </div>
    <% } %>

    <form action="/login" method="POST" class="space-y-5">
      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Username or Email</label>
        <input type="text" name="username" placeholder="Enter username..." required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-[#5865F2] transition">
      </div>

      <div>
        <div class="flex justify-between items-center mb-2">
          <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Password</label>
          <a href="#" class="text-xs text-[#5865F2] hover:underline">Forgot password?</a>
        </div>
        <input type="password" name="password" placeholder="••••••••••••" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-[#5865F2] transition">
      </div>

      <button type="submit" class="w-full py-3.5 bg-[#5865F2] hover:bg-[#4752C4] font-bold text-white text-sm rounded-xl shadow-lg transition transform hover:scale-[1.01]">
        Sign In to Portal
      </button>
    </form>

    <div class="mt-8 text-center border-t border-gray-800 pt-6">
      <p class="text-xs text-gray-500">Need a gaming community account? <a href="/register" class="text-[#5865F2] hover:underline font-semibold">Register here</a></p>
      <a href="/" class="block text-xs text-gray-400 hover:text-white mt-3 font-medium">← Back to CMS Homepage</a>
    </div>

  </div>

</body>
</html>
