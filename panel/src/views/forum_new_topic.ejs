<%- include('partials/header', { title: 'Publish New Discussion Topic' }) %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  
  <div class="bg-[#18191C] rounded-3xl border border-gray-800 p-8 sm:p-14 shadow-2xl">
    
    <div class="border-b border-gray-800 pb-6 mb-8">
      <a href="/forums" class="text-xs font-bold text-[#5865F2] hover:underline flex items-center space-x-1 mb-4">
        <span>← All Discussion Rooms</span>
      </a>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">Initiate New Topic</h1>
      <p class="text-xs text-gray-400 mt-1">Provide clear diagnostic summaries or complete Yolk specifications so community experts can evaluate your topic.</p>
    </div>

    <form action="/forums/new" method="POST" class="space-y-6">
      
      <!-- Category Selector -->
      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Discussion Category</label>
        <select name="category_id" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl px-5 py-4 text-white text-sm focus:outline-none focus:border-[#5865F2] transition">
          <option value="" disabled <%= !selectedCategoryId ? 'selected' : '' %>>-- Select an Appropriate Room --</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>" <%= selectedCategoryId == cat.id ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Title Input -->
      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Topic Header Title</label>
        <input type="text" name="title" placeholder="e.g. Critical diagnostic warning in Source CSGO Yoke or Minecraft Lag fixes" required class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl px-5 py-4 text-white text-sm focus:outline-none focus:border-[#5865F2] transition font-mono">
      </div>

      <!-- Content Textarea -->
      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Detailed Content Overview</label>
        <textarea name="content" rows="10" required placeholder="Describe your topic, post active stdout logs, or request Yolk configurations..." class="w-full bg-[#0E0F10] border border-gray-800 rounded-2xl p-5 text-white text-sm focus:outline-none focus:border-[#5865F2] transition resize-none leading-relaxed font-mono"></textarea>
      </div>

      <div class="pt-6 border-t border-gray-800 flex items-center justify-between">
        <a href="/forums" class="px-6 py-4 bg-gray-800 hover:bg-gray-700 font-semibold text-white text-sm rounded-2xl transition">Cancel</a>
        
        <button type="submit" class="px-10 py-4 bg-[#5865F2] hover:bg-[#4752C4] font-extrabold text-white text-base rounded-2xl shadow-2xl transition transform hover:scale-105 flex items-center space-x-2">
          <span>✨ Publish Discussion Topic</span>
        </button>
      </div>

    </form>

  </div>

</div>

<%- include('partials/footer') %>
